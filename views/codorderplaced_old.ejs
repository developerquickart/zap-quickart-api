                            <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top"><b>Total Amount</b></td>
                            </tr>
                            <% let total_amts = 0; %>
                            <% let total_amtsss = 0; %>
                            <% store_orderss.forEach(function(storeorders) { %>
                                <tr>
                                    <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                        <%= storeorders.order_cart_id %> || <%= storeorders.store_order_id %>
                                    </td>
                                    <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                        <img src="https://quickart.ae/admin/<%= storeorders.varient_image %>" style="width:auto;height:100px;display:block;margin:auto;">
                                    </td>
                                    <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                        <%= storeorders.product_name %> - <%= storeorders.quantity %> <%= storeorders.unit %>
                                    </td>
                                    <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                        <%= storeorders.qty %>
                                    </td>
                                    <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                         <%= storeorders.repeat_orders %>
                                        <% 
                                            let repeat_ordersss = 1;
                                            let total_deliverys = 1;
                                            let basic_prices = storeorders.price / storeorders.qty;
                                            let total_amt = basic_prices * storeorders.qty;
                                            total_amts += total_amt;
                                            let total_delivery = repeat_ordersss * total_deliverys;
                                            let items_prices = total_delivery * total_amt;
                                            total_amtsss += (total_amt * repeat_ordersss) * total_deliverys;
                                        %>
                                    </td>
                                      <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                        <%= storeorders.time_slot %>
                                    </td>
                                    <td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                        <%= basic_prices.toFixed(2) %>
                                    </td>
                                    <!--<td align="left" valign="middle" width="2%" bgcolor="#ffffff" valign="top">-->
                                   
                                    <!--</td>-->
                                    <td align="right" valign="middle" width="2%" bgcolor="#ffffff" valign="top">
                                        <%= items_prices.toFixed(2) %>
                                    </td>
                                </tr>
                            <% }); %>
                            
                            <% 
                            const tax = 5;
                            const GST_Amount = (total_amtsss - (total_amtsss * (100 / (100 + tax))));
                            const basic_Price = total_amtsss - GST_Amount;
                            const amount_paid = basic_Price + GST_Amount;
                        
                            const order_amt = basic_Price.toFixed(2);
                            const order_amt_vat_tax = GST_Amount.toFixed(2);
                            const order_amt_total = amount_paid.toFixed(2);
                        %>
                        
