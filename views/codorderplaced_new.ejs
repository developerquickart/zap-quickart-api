<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Email Template</title>
    <style>
      /* Reset some basic styles for consistency */
      body,
      table,
      td,
      a {
        text-size-adjust: 100%;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        padding: 0;
        font-size: 14px;
        font-family: Arial, sans-serif;
        background-color: #ffffff;
      }

      table {
        display: table;
        border-collapse: separate;
        box-sizing: border-box;
        text-indent: initial;
        unicode-bidi: isolate;
        border-spacing: 1px;
        border-color: gray;
      }
      /* Ensure Outlook styles work */
      .container {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
      }

      /* Style for mobile responsiveness */
      @media screen and (max-width: 600px) {
        .container {
          width: 100%;
        }
        .content {
          padding: 10px;
        }
      }
    </style>
  </head>
  <body style="margin: 0; padding: 0; background-color: #ffffff">
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      border="0"
      style="background-color: #ffffff"
    >
      <tr>
        <td align="left">
          <table
            class="container"
            cellpadding="0"
            cellspacing="0"
            style="border: 1px solid #2c347f; margin: 15px auto"
          >
            <tr style="padding: 20px 0; background-color: #f7f7f7">
              <td
                align="left"
                style="
                  padding: 0px 20px 0;
                  border-top: 20px solid #2c347f;
                  border-bottom: 2px solid #2c347f;
                "
              >
                <img
                  src="<%= baseurl %>/images/mail_logo/logo.png"
                  style="max-height: 80px"
                  class="img-fluid"
                />
              </td>
            </tr>
            <tr>
              <td class="content" style="padding: 10px 20px 0">
                <p style="color: #333333; font-size: 14px; margin: 0 0 10px">
                  Hello <%= user_name %>,
                </p>
                <p style="color: #333333; font-size: 14px; line-height: 1.5">
                  Your <%= group_id %> Order has been confirmed with QuicKart
                  successfully.
                </p>
                <p style="color: #333333; font-size: 14px; line-height: 1.5">
                  Thank you for choosing us!
                </p>
              </td>
            </tr>
            <tr>
              <td>
                <table
                  cellpadding="0"
                  cellspacing="0"
                  width="100%"
                  align="center"
                  valign="top"
                  class="table"
                >
                  <tbody>
                    <tr>
                      <td align="left" width="100%" valign="top">
                        <table
                          cellpadding="0"
                          cellspacing="0"
                          width="100%"
                          align="center"
                          valign="top"
                        >
                          <tbody>
                            <tr>
                              <td align="left" valign="top">
                                <table
                                  cellpadding="0"
                                  cellspacing="0"
                                  width="100%"
                                  align="center"
                                  valign="top"
                                  style="margin: 0 0 20px 0"
                                >
                                  <tbody>
                                    <tr>
                                      <td
                                        align="left"
                                        width="2%"
                                        valign="top"
                                      ></td>
                                      <td align="left" width="95%" valign="top">
                                        <table
                                          cellpadding="10"
                                          bgcolor="#ccc"
                                          cellspacing="1"
                                          width="90%"
                                          align="center"
                                          valign="top"
                                        >
                                          <tbody>
                                            <tr>
                                              <td
                                                colspan="9"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <center>
                                                  <b>Order Summary</b>
                                                </center>
                                              </td>
                                            </tr>
                                            <tr>
                                              <td
                                                colspan="2"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Name :</b>
                                              </td>
                                              <td
                                                colspan="7"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <%= user_name %>
                                              </td>
                                            </tr>
                                            <tr>
                                              <td
                                                colspan="2"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Address :</b>
                                              </td>
                                              <td
                                                colspan="7"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                               <%= orderss_address  %>
                                              </td>
                                            </tr>
                                            <tr>
                                              <td
                                                colspan="2"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Order ID :</b>
                                              </td>
                                              <td
                                                colspan="7"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                               <%= group_id %>
                                              </td>
                                            </tr>
                                            <tr>
                                              <td
                                                colspan="2"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Delivery Date : </b>
                                              </td>
                                              <td
                                                colspan="7"
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <%= delivery_date %>
                                              </td>
                                            </tr>
                                            <tr>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Product Order ID</b>
                                              </td>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Item Image</b>
                                              </td>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Item Details</b>
                                              </td>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Item Qty</b>
                                              </td>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Delivery Days</b>
                                              </td>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Delivery Slot</b>
                                              </td>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Item Price</b>
                                              </td>
                                              <td
                                                align="left"
                                                valign="middle"
                                                width="2%"
                                                bgcolor="#ffffff"
                                              >
                                                <b>Total Amount</b>
                                              </td>
                                            </tr>
                                             <% let total_amts = 0; %>
                                             <% let total_amtsss = 0; %>
                                             <% store_orderss.forEach(function(storeorders) { %>
                                                    <tr>
                                                      <td
                                                        align="left"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                        <%= storeorders.order_cart_id %>
                                                      </td>
                                                      <td
                                                        align="left"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                        <img
                                                        src="https://quickart.ae/admin/<%= storeorders.varient_image %>"
                                                          style="
                                                            width: 80px;
                                                            height: 80px;
                                                            object-fit: contain;
                                                            max-width: 80px;
                                                            display: block;
                                                            margin: auto;
                                                          "
                                                          class="CToWUd"
                                                          data-bit="iit"
                                                        />
                                                      </td>
                                                      <td
                                                        align="left"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                       <%= storeorders.product_name %> - <%= storeorders.quantity %> <%= storeorders.unit %>
                                                      </td>
                                                      <td
                                                        align="left"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                       <%= storeorders.qty %>
                                                      </td>
                                                      <td
                                                        align="left"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                       <%= storeorders.total_delivery %>
                                                      </td>
                                                      <td
                                                        align="left"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                        <%= storeorders.time_slot %>
                                                      </td>
                                                           <% 
                                            let repeat_ordersss = 1;
                                            let total_deliverys = 1;
                                            let basic_prices = storeorders.price / storeorders.qty;
                                            let total_amt = basic_prices * storeorders.qty;
                                            total_amts += total_amt;
                                            let total_delivery = repeat_ordersss * total_deliverys;
                                            let items_prices = total_delivery * total_amt;
                                            total_amtsss += (total_amt * repeat_ordersss) * total_deliverys;
                                        %>
                                                      <td
                                                        align="left"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                       <%= basic_prices.toFixed(2) %>
                                                      </td>
                                                      <td
                                                        align="right"
                                                        valign="middle"
                                                        width="2%"
                                                        bgcolor="#ffffff"
                                                      >
                                                         <%= items_prices.toFixed(2) %>
                                                      </td>
                                                    </tr>
                                            <% }); %>
                                          </tbody>
                                        </table>
                                      </td>
                                      <td
                                        align="left"
                                        width="10%"
                                        valign="top"
                                      ></td>
                                    </tr>
                                  </tbody>
                                </table>
                              </td>
                            </tr>
                            <tr>
                              <td
                                align="left"
                                valign="top"
                                style="padding: 0px 0 0 0"
                              >
                                <table
                                  cellpadding="0"
                                  cellspacing="0"
                                  width="100%"
                                  align="center"
                                  valign="top"
                                >
                                  <tbody>
                                    <tr>
                                      <td
                                        align="left"
                                        width="2%"
                                        valign="top"
                                      ></td>
                                      <td align="left" width="95%" valign="top">
                                        <table
                                          cellpadding="0"
                                          cellspacing="0"
                                          width="100%"
                                          align="center"
                                          valign="top"
                                        >
                                          <tbody>
                                            <tr>
                                              <td
                                                align="left"
                                                width="5%"
                                                valign="top"
                                                style="
                                                  font-size: 14px;
                                                  padding: 0 0 0 0;
                                                "
                                              >
                                                Cheers!<br /><br />
                                                We are here to make your fresh
                                                essentials shopping experience
                                                exceptional<br /><br />
                                                Item(s) will be delivered to you
                                                according to the specified time
                                                slot.<br /><br />
                                              </td>
                                            </tr>
                                          </tbody>
                                        </table>
                                      </td>
                                    </tr>
                                  </tbody>
                                </table>
                              </td>
                            </tr>

                           
                          </tbody>
                        </table>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
