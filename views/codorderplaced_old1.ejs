<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="format-detection" content="telephone=no">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
  <link rel="icon" type="image/png" sizes="16x16" href="images/mail_logo/favicon.ico">
  <title>Challan</title>
  <style>
  @font-face {
    font-family: Metropolis-Regular;
    src: url(fonts/Metropolis-Regular.otf);
  }
  @font-face {
    font-family: Metropolis-Bold;
    src: url(fonts/Metropolis-Bold.otf);
  }
  </style>
</head>
<body style="font-family: arial;font-size: 15px;line-height: normal;font-weight: normal; color:#000;">
  <div class="mainbox" style="max-width: 700px;margin: 0 auto;">
    <div class="width100" style="float: left;width: 100%;border: 1px solid #2C347F;margin: 15px 0;background-color:#f7f7f7;">
      <div class="container">
        <div class="row">
          <div style="margin: 0 0 10px 20;padding: 10px 20px;border-top: 20px solid #2C347F; border-bottom: 2px solid #2C347F" class="col-lg-12"><img src="<%= baseurl %>/images/mail_logo/logo.png" style="max-height: 70px;" class="img-fluid"></div>
        </div>
        <div class="row">
          <div class="col-lg-12" style="margin-bottom: 15px;">
            <div class="row">
              <div class="col-lg-12" style="padding-left: 30px; padding-top: 10px;">
                Hello,<br><br>
                Your <%= group_id %> Order has been confirmed with QuicKart successfully.
              </div>
            </div>
          </div>
        </div>
        <div class="row" style="display: grid;">
          <div class="col-lg-12" style="padding: 20px 30px 20px 30px;margin: 0 0 20px 0;">
            <div class="row">
              <div class="col-lg-12" style="margin-bottom: 16px; color:#000;">Thank you for choosing us!</div>
            </div>
            <div class="row">
              <div class="col-lg-12">
                <div class="tabbing_four_inner_table table-responsive" style="background-color:#fff;margin: 0 0 10px 0;float: left;width: 100%;">
                  <table class="table" style="margin: 0;float: left;width: 100%;table-layout: fixed;border: 2px solid #2C347F;border-collapse: collapse;">
                    <thead class="table-danger">
                      <tr style="">
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Product Order ID </th>
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Delivery Slot </th>
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Delivery Date </th>
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Product Image</th>
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Product Name </th>
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Qty </th>
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Price </th>
                        <th scope="col" style="padding: 6px;background-color: #FFF;border: 1px solid #DDDDDD;font-size:14px;">Amount</th>
                      </tr>
                    </thead>
                    <tbody>
                     <% let total_amts = 0; %>
                     <% let total_amtsss = 0; %>
                     <% store_orderss.forEach(function(storeorders) { %>
                      <tr>
                        <td scope="col" style="padding: 6px;border: 1px solid #DDDDDD; font-size:14px;"> <%= storeorders.order_cart_id %> </td>
                        <td scope="col" style="padding: 6px;border: 1px solid #DDDDDD; font-size:14px;"> <%= storeorders.time_slot %> </td>
                        <td scope="col" style="padding: 6px;border: 1px solid #DDDDDD; font-size:14px;"> <%= delivery_date %> </td>
                        <td scope="col" style="padding: 6px;border: 1px solid #DDDDDD; font-size:14px;">  <img src="https://quickart.ae/admin/<%= storeorders.varient_image %>" style="width:auto;height:auto;max-width:70%;display:block;margin:auto;"></td>
                        <td scope="col" style="padding: 6px;border: 1px solid #DDDDDD; font-size:14px;"> <%= storeorders.product_name %> - <%= storeorders.quantity %> <%= storeorders.unit %></td>
                        <td scope="col" style="padding: 6px;border: 1px solid #DDDDDD; font-size:14px;"> <%= storeorders.qty %></td>
                        <td scope="col" style="padding: 6px;border: 1px solid #DDDDDD; font-size:14px;">
                                 <% 
                                            let repeat_ordersss = 1;
                                            let total_deliverys = 1;
                                            let basic_prices = storeorders.price / storeorders.qty;
                                            let total_amt = basic_prices * storeorders.qty;
                                            total_amts += total_amt;
                                            let total_delivery = repeat_ordersss * total_deliverys;
                                            let items_prices = total_delivery * total_amt;
                                            total_amtsss += (total_amt * repeat_ordersss) * total_deliverys;
                                        %>
                            
                             <%= basic_prices.toFixed(2) %></td>
                        <td scope="col" style="padding: 15px 20px;border: 1px solid #DDDDDD;">
                                   
                           <%= items_prices.toFixed(2) %>
                        </td>
                      </tr>
                      <% }); %>
                    
                      <!-- <tr style="background-color: #EFF3F6;">
                        <td scope="col" colspan="4" style="padding: 15px 20px;border: 1px solid #DDDDDD;">Net Total:</td>
                        <td scope="col" style="padding: 15px 20px;border: 1px solid #DDDDDD;">AED</td>
                      </tr> -->
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="row" style="padding-left: 20px;">
           <div class="col-lg-12" style="margin-bottom: 15px; color:#000;"><b>Address: </b><%= orderss_address %></div>
          <div class="col-lg-12" style="margin-bottom: 15px; color:#000;">Cheers!</div>
          <div class="col-lg-12" style="margin-bottom: 15px; color:#000;">We are here to make your fresh essentials<br>shopping experience exceptional</div>
          <div class="col-lg-12" style="margin-bottom: 15px; color:#000;">Item(s) will be delivered to you according to the specified time slot.</div>
        </div>
        <div class="row">
          <div class="col-lg-12" style="padding: 0 0 10px 0;text-align: center; background-color: #F7F7F7; position: relative;">
            <div class="foote_socialicon">
              <table style="width: 100%;">
                <tbody>
                  <tr>
                    <td>
                      <a href="https://www.facebook.com/QuicKart.uae" target="_blank"><img src="<%= baseurl %>/images/mail_logo/facebook.png" class="img-fluid" style="max-height: 30px;"></a>
                      <a href="https://twitter.com/Quickartuae/" target="_blank"><img src="<%= baseurl %>/images/mail_logo/twitter.png" class="img-fluid" style="max-height: 30px;"></a>
                      <a href="https://www.instagram.com/quickartuae/" target="_blank"><img src="<%= baseurl %>/images/mail_logo/instagram.png" class="img-fluid" style="max-height: 30px;"></a>
                      <a href="https://www.linkedin.com/company/quickart-general-trading-llc/" target="_blank"><img src="<%= baseurl %>/images/mail_logo/linkeding.png" class="img-fluid" style="max-height: 30px;"></a>
                      <a href="https://www.youtube.com/@quickartuae7767" target="_blank"><img src="<%= baseurl %>/images/mail_logo/youtube.png" class="img-fluid" style="max-height: 30px;"></a>
                      <a href="https://play.google.com/store/apps/details?id=com.quickart.customer&pli=1" target="_blank"><img src="<%= baseurl %>/images/mail_logo/googleplay.png" class="img-fluid" style="max-height: 30px;"></a>
                      <a href="https://apps.apple.com/in/app/quickart/id1624846848" target="_blank"><img src="<%= baseurl %>/images/mail_logo/appstore.png" class="img-fluid" style="max-height: 30px;"></a>
                    </td>
                    <td></td>
                    <td>
                      <a href="#" class="qrcode">
                        <img src="<%= baseurl %>/images/mail_logo/qrcode.png" class="img-fluid" style="max-height: 100px;">
                      </a>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-lg-12" style="border-bottom: 20px solid #2C347F;margin: 10px 0 0 0;"></div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>